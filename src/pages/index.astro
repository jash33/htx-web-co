---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import DifferentiatorsSection from '../components/DifferentiatorsSection.astro';
import FeaturedProjectsPreview from '../components/FeaturedProjectsPreview.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import type { Service } from '../types/service';
import type { Differentiator } from '../types/differentiator';
import { DEFAULT_FAQ_ITEMS } from '../types/faq';
import { localBusinessSchema } from '../config/seo.config';
import { FEATURED_PROJECTS, FEATURED_PROJECTS_CONFIG } from '../config/featured-projects.config';

/**
 * Homepage - HTX Web Co.
 * Main landing page showcasing services and value proposition.
 */

// SVG Icons for services (optimized inline SVGs)
const icons = {
	webDesign: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M4 4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2H4zm0 2h16v9H4V6zm0 11h16v1H4v-1z"/><path d="M6 8h3v3H6V8zm5 0h7v1h-7V8zm0 2h5v1h-5v-1z"/></svg>`,
	ecommerce: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>`,
	customApps: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/></svg>`,
	aiAgent: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1-2.73 2.71-2.73 7.08 0 9.79s7.15 2.71 9.88 0C18.32 15.65 19 14.08 19 12.1h2c0 1.98-.88 4.55-2.64 6.29-3.51 3.48-9.21 3.48-12.72 0-3.5-3.47-3.53-9.11-.02-12.58s9.14-3.47 12.65 0L21 3v7.12zM12.5 8v4.25l3.5 2.08-.72 1.21L11 13V8h1.5z"/></svg>`,
};

// SVG Icons for differentiators (optimized inline SVGs)
const differentiatorIcons = {
	localExpertise: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>`,
	transparentPricing: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>`,
	fastTurnaround: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>`,
	personalizedService: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>`,
};

// Service offerings for the homepage
const services: Service[] = [
	{
		id: 'website-design',
		title: 'Website Design',
		description: 'Custom websites with hosting, maintenance, and ongoing support included. Need a CMS? Optional. Want to make your own updates? You can. Already have a site? I can add features or improve what you\'ve got.',
		icon: icons.webDesign,
		cta: {
			text: 'Learn More',
			href: '/htx-web-co/services/website-design',
		},
	},
	{
		id: 'ecommerce',
		title: 'Ecommerce Setups',
		description: 'Get your online store up and running with Wix or Shopify. From product listings to payment processing, I\'ll handle the technical setup so you can focus on selling.',
		icon: icons.ecommerce,
		cta: {
			text: 'Learn More',
			href: '/htx-web-co/services/ecommerce',
		},
	},
	{
		id: 'custom-apps',
		title: 'Custom Apps',
		description: 'Need software tailored to your specific needs? I build custom web applications for personal use or business operations—dashboards, tools, workflows, and more.',
		icon: icons.customApps,
		cta: {
			text: 'Learn More',
			href: '/htx-web-co/services/custom-apps',
		},
	},
	{
		id: 'ai-agents',
		title: 'Personal AI Agents',
		description: 'Your own AI assistant that works for you 24/7. Powered by OpenClaw, these agents can handle tasks, answer questions, and integrate with your business tools.',
		icon: icons.aiAgent,
		cta: {
			text: 'Learn More',
			href: '/htx-web-co/services/ai-agents',
		},
	},
];

// Differentiators - unique selling points
const differentiators: Differentiator[] = [
	{
		id: 'professional',
		title: 'Professional',
		description: '10 years of experience building websites and applications. You get expert-level work without the agency price tag.',
		icon: differentiatorIcons.localExpertise,
	},
	{
		id: 'affordable',
		title: 'Affordable',
		description: 'Quality work at fair prices. No hidden fees, no surprise charges—just transparent pricing that fits your budget.',
		icon: differentiatorIcons.transparentPricing,
	},
	{
		id: 'fast',
		title: 'Fast',
		description: 'Most projects are completed within 2-4 weeks. I respect your time and deliver on schedule.',
		icon: differentiatorIcons.fastTurnaround,
	},
	{
		id: 'tailored',
		title: 'Tailored to You',
		description: 'No cookie-cutter templates. Every solution is customized to your unique business needs and goals.',
		icon: differentiatorIcons.personalizedService,
	},
];
---

<Layout
	title="HTX Web Co."
	description="Houston web design, hosting, maintenance, and business automation services for small businesses. Custom websites, ongoing support, and solutions to help your local business grow online."
	noTitleTemplate
	openGraph={{
		type: 'website',
	}}
	jsonLd={localBusinessSchema}
>
	<main>
		<!-- Hero Section -->
		<HeroSection
			headline="Web Products That Elevate Houston Businesses"
			primaryCTA={{
				text: "Get Your Free Consultation",
				href: "/htx-web-co/contact",
			}}
			secondaryCTA={{
				text: "See How It Works",
				href: "#services",
			}}
			trustBadges={[
				{ icon: 'experience', text: '10+ Years Experience' },
			]}
		/>

		<!-- Services Section -->
		<ServicesSection
			id="services"
			heading="Our Services"
			subheading="Comprehensive web solutions to help your Houston business thrive online. From design to maintenance, we've got you covered."
			services={services}
			columns={4}
		/>

		<!-- Why Choose Us / Differentiators Section -->
		<DifferentiatorsSection
			id="why-choose-us"
			heading="Why Choose Us"
			subheading="Here's what sets us apart from other web service providers in the Houston area."
			differentiators={differentiators}
		/>

		<!-- Featured Projects Preview Section -->
		<FeaturedProjectsPreview
			id={FEATURED_PROJECTS_CONFIG.id}
			heading={FEATURED_PROJECTS_CONFIG.heading}
			subheading={FEATURED_PROJECTS_CONFIG.subheading}
			projects={FEATURED_PROJECTS}
			viewAllText={FEATURED_PROJECTS_CONFIG.viewAllText}
			viewAllHref={FEATURED_PROJECTS_CONFIG.viewAllHref}
		/>

		<!-- FAQ Section -->
		<FAQAccordion
			items={DEFAULT_FAQ_ITEMS}
			heading="Frequently Asked Questions"
			subheading="Find answers to common questions about our web design services, pricing, and process."
			allowMultiple={false}
			initialExpanded={null}
		/>

	</main>
</Layout>
