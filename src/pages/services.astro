---
/**
 * Pricing Page - HTX Web Co.
 * Simple, transparent pricing for all services.
 */

import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

// Service pricing data
const services = [
  {
    id: 'website-design',
    name: 'Website Design',
    description: 'Custom websites with hosting and maintenance included. CMS optional—make your own updates if you want. Already have a site? I can add features or improve it.',
    price: 'From $499',
    features: [
      'Custom design tailored to your brand',
      'Mobile-responsive on all devices',
      'Hosting & maintenance included',
      'SEO-optimized for search engines',
      'CMS optional (edit content yourself)',
      'Existing site updates available',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M4 4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2H4zm0 2h16v9H4V6zm0 11h16v1H4v-1z"/><path d="M6 8h3v3H6V8zm5 0h7v1h-7V8zm0 2h5v1h-5v-1z"/></svg>`,
    cta: 'Get Started',
    href: '/htx-web-co/contact?service=website-design',
  },
  {
    id: 'ecommerce',
    name: 'Ecommerce Setups',
    description: 'Get your online store up and running with Wix or Shopify. Product listings, payment processing, shipping—I handle the technical setup.',
    price: 'From $799',
    features: [
      'Wix or Shopify store setup',
      'Product catalog configuration',
      'Payment processing integration',
      'Shipping & tax setup',
      'Mobile-optimized storefront',
      'Training on how to manage it',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>`,
    cta: 'Get Started',
    href: '/htx-web-co/contact?service=ecommerce',
  },
  {
    id: 'custom-apps',
    name: 'Custom Apps',
    description: 'Software built specifically for you. Personal tools, business dashboards, workflow automation—if you can describe it, I can build it.',
    price: 'Custom Quote',
    features: [
      'Tailored to your exact needs',
      'Web-based (works anywhere)',
      'Personal or business use',
      'Dashboards & data tools',
      'Workflow automation',
      'Integrations with other services',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/></svg>`,
    cta: 'Discuss Your Project',
    href: '/htx-web-co/contact?service=custom-apps',
  },
  {
    id: 'ai-agents',
    name: 'Personal AI Agents',
    description: 'Your own AI assistant that works 24/7. Powered by OpenClaw. Handles tasks, answers questions, integrates with your tools.',
    price: 'From $199/mo',
    features: [
      'Personal AI assistant setup',
      'Works across devices',
      'Integrates with your business tools',
      'Handles routine tasks automatically',
      'Available 24/7',
      'Ongoing support & updates',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1-2.73 2.71-2.73 7.08 0 9.79s7.15 2.71 9.88 0C18.32 15.65 19 14.08 19 12.1h2c0 1.98-.88 4.55-2.64 6.29-3.51 3.48-9.21 3.48-12.72 0-3.5-3.47-3.53-9.11-.02-12.58s9.14-3.47 12.65 0L21 3v7.12zM12.5 8v4.25l3.5 2.08-.72 1.21L11 13V8h1.5z"/></svg>`,
    cta: 'Learn More',
    href: '/htx-web-co/contact?service=ai-agents',
  },
];
---

<Layout
  title="Pricing"
  description="Transparent pricing for website design, ecommerce, custom apps, and AI agents. No hidden fees—just quality work at fair prices."
>
  <main>
    <!-- Hero Section -->
    <section class="pricing-hero">
      <div class="pricing-hero__container">
        <h1 class="pricing-hero__title">Simple, Transparent Pricing</h1>
        <p class="pricing-hero__subtitle">
          No hidden fees. No surprise charges. Just quality work at fair prices.
        </p>
      </div>
    </section>

    <!-- Pricing Cards Section -->
    <section class="pricing-cards">
      <div class="pricing-cards__container">
        <div class="pricing-cards__grid">
          {services.map((service) => (
            <div class="pricing-card" id={service.id}>
              <div class="pricing-card__icon" set:html={service.icon} />
              <h2 class="pricing-card__name">{service.name}</h2>
              <p class="pricing-card__description">{service.description}</p>
              <div class="pricing-card__price">{service.price}</div>
              <ul class="pricing-card__features">
                {service.features.map((feature) => (
                  <li class="pricing-card__feature">
                    <svg class="pricing-card__check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
              <Button
                text={service.cta}
                href={service.href}
                variant="primary"
                size="large"
                fullWidth
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="pricing-cta">
      <div class="pricing-cta__container">
        <h2 class="pricing-cta__title">Not Sure What You Need?</h2>
        <p class="pricing-cta__text">
          Let's talk. I'll help you figure out the best solution for your situation—no obligation.
        </p>
        <Button
          text="Schedule a Free Consultation"
          href="/htx-web-co/contact"
          variant="primary"
          size="large"
        />
      </div>
    </section>
  </main>
</Layout>

<style>
  /* =================================================================
   * PRICING HERO
   * ================================================================= */
  .pricing-hero {
    padding: var(--spacing-16) var(--spacing-4) var(--spacing-12);
    background: linear-gradient(
      135deg,
      var(--color-primary-900) 0%,
      var(--color-primary-700) 100%
    );
    text-align: center;
  }

  .pricing-hero__container {
    max-width: var(--container-4xl);
    margin: 0 auto;
  }

  .pricing-hero__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-inverse);
    margin: 0 0 var(--spacing-4) 0;
    line-height: var(--line-height-tight);
  }

  .pricing-hero__subtitle {
    font-family: var(--font-body);
    font-size: var(--font-size-lg);
    color: var(--color-primary-100);
    margin: 0;
    max-width: 50ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* =================================================================
   * PRICING CARDS
   * ================================================================= */
  .pricing-cards {
    padding: var(--spacing-16) var(--spacing-4);
    background-color: var(--color-background);
  }

  .pricing-cards__container {
    max-width: var(--container-7xl);
    margin: 0 auto;
  }

  .pricing-cards__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-8);
  }

  @media (min-width: 640px) {
    .pricing-cards__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .pricing-cards__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
    padding: var(--spacing-6);
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: all var(--duration-200) var(--ease-out);
  }

  .pricing-card:hover {
    border-color: var(--color-primary-300);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .pricing-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--spacing-14);
    height: var(--spacing-14);
    margin-bottom: var(--spacing-4);
    background-color: var(--color-accent-subtle);
    border-radius: var(--radius-lg);
    color: var(--color-primary-700);
  }

  .pricing-card__icon :global(svg) {
    width: var(--spacing-7);
    height: var(--spacing-7);
  }

  .pricing-card__name {
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    margin: 0 0 var(--spacing-2) 0;
  }

  .pricing-card__description {
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin: 0 0 var(--spacing-4) 0;
    flex-grow: 0;
  }

  .pricing-card__price {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
    margin-bottom: var(--spacing-6);
  }

  .pricing-card__features {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--spacing-6) 0;
    flex-grow: 1;
  }

  .pricing-card__feature {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-2);
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-2);
    line-height: var(--line-height-relaxed);
  }

  .pricing-card__check {
    flex-shrink: 0;
    width: var(--spacing-4);
    height: var(--spacing-4);
    color: var(--color-accent);
    margin-top: 2px;
  }

  /* =================================================================
   * PRICING CTA
   * ================================================================= */
  .pricing-cta {
    padding: var(--spacing-16) var(--spacing-4);
    background-color: var(--color-accent-subtle);
    text-align: center;
  }

  .pricing-cta__container {
    max-width: var(--container-3xl);
    margin: 0 auto;
  }

  .pricing-cta__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    margin: 0 0 var(--spacing-4) 0;
  }

  .pricing-cta__text {
    font-family: var(--font-body);
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    margin: 0 0 var(--spacing-8) 0;
    max-width: 50ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* =================================================================
   * RESPONSIVE
   * ================================================================= */
  @media (min-width: 640px) {
    .pricing-hero__title {
      font-size: var(--font-size-5xl);
    }
  }
</style>
