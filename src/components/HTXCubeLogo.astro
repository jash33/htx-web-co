---
/**
 * HTX Cube Logo
 * Static version of BlockBuilder cube with H, T, X letters
 * Based on the completed state of the block animation
 */

interface Props {
  size?: number;
  class?: string;
}

const { size = 200, class: className = '' } = Astro.props;
---

<div class={`htx-cube-logo ${className}`}>
  <canvas id="htx-logo-canvas" width={size} height={size}></canvas>
</div>

<style>
  .htx-cube-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #htx-logo-canvas {
    display: block;
  }
</style>

<script>
  import * as THREE from 'three';
  import { FontLoader } from 'three/addons/loaders/FontLoader.js';
  import { TextGeometry } from 'three/addons/geometries/TextGeometry.js';

  function initHTXLogo() {
    const canvas = document.getElementById('htx-logo-canvas') as HTMLCanvasElement;
    if (!canvas || canvas.dataset.initialized) return;
    canvas.dataset.initialized = 'true';

    // Scene setup
    const scene = new THREE.Scene();
    scene.background = null;
    
    // Isometric camera
    const aspect = 1;
    const frustumSize = 6;
    const camera = new THREE.OrthographicCamera(
      -frustumSize * aspect / 2,
      frustumSize * aspect / 2,
      frustumSize / 2,
      -frustumSize / 2,
      0.1,
      100
    );
    camera.position.set(5, 4, 5);
    camera.lookAt(0, 0, 0);

    // Renderer
    const renderer = new THREE.WebGLRenderer({ 
      canvas, 
      antialias: true,
      alpha: true 
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Brand colors - Darker palette
    const colors = {
      steelBlue: 0x3A7CA8,    // Top faces
      mediumBlue: 0x4A90C4,   // Alternating tops
      navy: 0x1E4B6E,         // Left/front faces
      deepNavy: 0x14354F,     // Right/back faces
      white: 0xFFFFFF,
    };

    // Block positions - 2x2x2 cube in final state
    const blockConfigs = [
      // Bottom layer
      { x: 0.55, y: -0.55, z: 0.55, topColor: colors.steelBlue },
      { x: -0.55, y: -0.55, z: 0.55, topColor: colors.mediumBlue },
      { x: 0.55, y: -0.55, z: -0.55, topColor: colors.steelBlue },
      { x: -0.55, y: -0.55, z: -0.55, topColor: colors.mediumBlue },
      // Top layer
      { x: 0.55, y: 0.55, z: 0.55, topColor: colors.steelBlue },
      { x: -0.55, y: 0.55, z: 0.55, topColor: colors.mediumBlue },
      { x: 0.55, y: 0.55, z: -0.55, topColor: colors.steelBlue },
      { x: -0.55, y: 0.55, z: -0.55, topColor: colors.mediumBlue },
    ];

    // Create blocks group
    const blocksGroup = new THREE.Group();
    scene.add(blocksGroup);
    
    const blockGeometry = new THREE.BoxGeometry(0.95, 0.95, 0.95);
    
    blockConfigs.forEach((config) => {
      const materials = [
        new THREE.MeshBasicMaterial({ color: colors.deepNavy }), // right (+X)
        new THREE.MeshBasicMaterial({ color: colors.navy }),     // left (-X)
        new THREE.MeshBasicMaterial({ color: config.topColor }), // top (+Y)
        new THREE.MeshBasicMaterial({ color: colors.deepNavy }), // bottom (-Y)
        new THREE.MeshBasicMaterial({ color: colors.navy }),     // front (+Z)
        new THREE.MeshBasicMaterial({ color: colors.deepNavy }), // back (-Z)
      ];
      
      const block = new THREE.Mesh(blockGeometry, materials);
      block.position.set(config.x, config.y, config.z); // Final position (no animation)
      blocksGroup.add(block);
    });

    // Render once (static)
    renderer.render(scene, camera);

    // Cleanup on page navigation
    document.addEventListener('astro:before-swap', () => {
      renderer.dispose();
    });
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHTXLogo);
  } else {
    initHTXLogo();
  }
  
  document.addEventListener('astro:page-load', initHTXLogo);
</script>
