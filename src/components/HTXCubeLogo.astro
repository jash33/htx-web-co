---
/**
 * HTX Cube Logo
 * Solid isometric cube with H, T, X letters on faces
 */

interface Props {
  size?: number;
  class?: string;
}

const { size = 200, class: className = '' } = Astro.props;
---

<div class={`htx-cube-logo ${className}`} style={`width: ${size}px; height: ${size}px;`}>
  <svg viewBox="0 0 200 180" xmlns="http://www.w3.org/2000/svg">
    <!-- 
      Solid isometric cube with HTX letters
      - Top face: T bar going diagonal
      - Left face: H letter
      - Right face: X letter
    -->
    
    <!-- CUBE FACES - Solid completed cube -->
    <!-- Top face (diamond shape) -->
    <polygon 
      points="100,10 170,45 100,80 30,45" 
      fill="var(--color-accent, #5BC0C4)"
    />
    
    <!-- Left face (parallelogram) -->
    <polygon 
      points="30,45 100,80 100,150 30,115" 
      fill="var(--color-primary-500, #4A90C4)"
    />
    
    <!-- Right face (parallelogram) -->
    <polygon 
      points="100,80 170,45 170,115 100,150" 
      fill="var(--color-primary-800, #1E4B6E)"
    />
    
    <!-- LETTER T - on top face, bar going diagonal -->
    <!-- T horizontal bar across top -->
    <polygon 
      points="55,32 100,10 145,32 145,38 100,16 55,38" 
      fill="white"
      opacity="0.95"
    />
    <!-- T vertical stem down center of top face -->
    <polygon 
      points="95,18 105,18 105,65 95,65" 
      fill="white"
      opacity="0.9"
    />
    
    <!-- LETTER H - on left face -->
    <!-- H left vertical stroke -->
    <polygon 
      points="45,55 52,59 52,105 45,101" 
      fill="white"
      opacity="0.95"
    />
    <!-- H right vertical stroke -->
    <polygon 
      points="75,72 82,76 82,122 75,118" 
      fill="white"
      opacity="0.95"
    />
    <!-- H horizontal bar -->
    <polygon 
      points="45,75 82,95 82,102 45,82" 
      fill="white"
      opacity="0.95"
    />
    
    <!-- LETTER X - on right face -->
    <!-- X diagonal stroke 1 (top-left to bottom-right) -->
    <polygon 
      points="118,55 126,51 155,105 147,109" 
      fill="white"
      opacity="0.95"
    />
    <!-- X diagonal stroke 2 (top-right to bottom-left) -->
    <polygon 
      points="147,55 155,51 126,105 118,109" 
      fill="white"
      opacity="0.95"
    />
    
    <!-- WEB CO text below -->
    <text 
      x="100" 
      y="172" 
      text-anchor="middle" 
      fill="var(--color-primary-900, #14354F)"
      font-family="var(--font-heading, 'Montserrat', sans-serif)" 
      font-weight="700"
      font-size="18"
      letter-spacing="4"
    >
      WEB CO
    </text>
  </svg>
</div>

<style>
  .htx-cube-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  
  .htx-cube-logo svg {
    width: 100%;
    height: 100%;
  }
</style>
