---
/**
 * HTX Cube Logo
 * Static version of BlockBuilder cube - same rendering approach as animated version
 */

interface Props {
  size?: number;
  class?: string;
}

const { size = 200, class: className = '' } = Astro.props;
---

<div class={`htx-cube-logo ${className}`} style={`--logo-size: ${size}px;`}>
  <canvas class="htx-cube-logo__canvas" width={size} height={size}></canvas>
</div>

<style>
  .htx-cube-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .htx-cube-logo__canvas {
    display: block;
    width: var(--logo-size);
    height: var(--logo-size);
  }
</style>

<script>
  import * as THREE from 'three';

  function initHTXLogo() {
    const canvases = document.querySelectorAll('.htx-cube-logo__canvas:not([data-initialized])');
    canvases.forEach((canvas) => {
      initSingleCube(canvas as HTMLCanvasElement);
    });
  }

  function initSingleCube(canvas: HTMLCanvasElement) {
    canvas.dataset.initialized = 'true';

    // Scene setup
    const scene = new THREE.Scene();
    scene.background = null;
    
    // Isometric camera (same as BlockBuilder)
    const aspect = 1;
    const frustumSize = 6;
    const camera = new THREE.OrthographicCamera(
      -frustumSize * aspect / 2,
      frustumSize * aspect / 2,
      frustumSize / 2,
      -frustumSize / 2,
      0.1,
      100
    );
    camera.position.set(5, 4, 5);
    camera.lookAt(0, 0, 0);

    // Renderer - same setup as BlockBuilder animated version
    const renderer = new THREE.WebGLRenderer({ 
      canvas, 
      antialias: true,
      alpha: true 
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Brand colors (same as BlockBuilder)
    const colors = {
      iceBlue: 0xB5D8F0,
      baseSkyBlue: 0x67ACE0,
      deepSteelBlue: 0x3A7CA8,
      deepNavy: 0x1E4B6E,
      softTeal: 0x5BC0C4,
      white: 0xFFFFFF,
    };

    // Block positions - 2x2x2 cube in final state
    const blockConfigs = [
      // Bottom layer
      { x: 0.55, y: -0.55, z: 0.55, topColor: colors.iceBlue },
      { x: -0.55, y: -0.55, z: 0.55, topColor: colors.iceBlue },
      { x: 0.55, y: -0.55, z: -0.55, topColor: colors.iceBlue },
      { x: -0.55, y: -0.55, z: -0.55, topColor: colors.iceBlue },
      // Top layer
      { x: 0.55, y: 0.55, z: 0.55, topColor: colors.iceBlue },
      { x: -0.55, y: 0.55, z: 0.55, topColor: colors.iceBlue },
      { x: 0.55, y: 0.55, z: -0.55, topColor: colors.iceBlue },
      { x: -0.55, y: 0.55, z: -0.55, topColor: colors.iceBlue },
    ];

    // Create blocks group
    const blocksGroup = new THREE.Group();
    scene.add(blocksGroup);
    
    const blockGeometry = new THREE.BoxGeometry(0.95, 0.95, 0.95);
    
    blockConfigs.forEach((config) => {
      const materials = [
        new THREE.MeshBasicMaterial({ color: colors.deepNavy }), // right (+X)
        new THREE.MeshBasicMaterial({ color: colors.deepSteelBlue }), // left (-X)
        new THREE.MeshBasicMaterial({ color: config.topColor }), // top (+Y)
        new THREE.MeshBasicMaterial({ color: colors.deepNavy }), // bottom (-Y)
        new THREE.MeshBasicMaterial({ color: colors.deepSteelBlue }), // front (+Z)
        new THREE.MeshBasicMaterial({ color: colors.deepNavy }), // back (-Z)
      ];
      
      const block = new THREE.Mesh(blockGeometry, materials);
      block.position.set(config.x, config.y, config.z);
      blocksGroup.add(block);
    });

    // Render once (static)
    renderer.render(scene, camera);

    // Cleanup on page navigation
    document.addEventListener('astro:before-swap', () => {
      renderer.dispose();
    });
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHTXLogo);
  } else {
    initHTXLogo();
  }
  
  document.addEventListener('astro:page-load', initHTXLogo);
</script>
