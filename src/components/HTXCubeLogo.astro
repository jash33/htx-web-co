---
/**
 * HTX Cube Logo
 * Static version of BlockBuilder cube with H, T, X letters
 * Based on the completed state of the block animation
 */

interface Props {
  size?: number;
  class?: string;
}

const { size = 200, class: className = '' } = Astro.props;
---

<div class={`htx-cube-logo ${className}`}>
  <canvas id="htx-logo-canvas" width={size} height={size}></canvas>
</div>

<style>
  .htx-cube-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #htx-logo-canvas {
    display: block;
  }
</style>

<script>
  import * as THREE from 'three';
  import { FontLoader } from 'three/addons/loaders/FontLoader.js';
  import { TextGeometry } from 'three/addons/geometries/TextGeometry.js';

  function initHTXLogo() {
    const canvas = document.getElementById('htx-logo-canvas') as HTMLCanvasElement;
    if (!canvas || canvas.dataset.initialized) return;
    canvas.dataset.initialized = 'true';

    // Scene setup
    const scene = new THREE.Scene();
    scene.background = null;
    
    // Isometric camera
    const aspect = 1;
    const frustumSize = 6;
    const camera = new THREE.OrthographicCamera(
      -frustumSize * aspect / 2,
      frustumSize * aspect / 2,
      frustumSize / 2,
      -frustumSize / 2,
      0.1,
      100
    );
    camera.position.set(5, 4, 5);
    camera.lookAt(0, 0, 0);

    // Renderer
    const renderer = new THREE.WebGLRenderer({ 
      canvas, 
      antialias: true,
      alpha: true 
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Brand colors - Sky Blue palette (no teal)
    const colors = {
      skyBlue: 0x67ACE0,      // Primary - top faces
      iceBlue: 0xB5D8F0,      // Light - alternating tops
      steelBlue: 0x4A90C4,    // Medium - left/front faces
      navy: 0x1E4B6E,         // Dark - right/back faces
      white: 0xFFFFFF,
    };

    // Block positions - 2x2x2 cube in final state
    const blockConfigs = [
      // Bottom layer
      { x: 0.55, y: -0.55, z: 0.55, topColor: colors.skyBlue },
      { x: -0.55, y: -0.55, z: 0.55, topColor: colors.iceBlue },
      { x: 0.55, y: -0.55, z: -0.55, topColor: colors.skyBlue },
      { x: -0.55, y: -0.55, z: -0.55, topColor: colors.iceBlue },
      // Top layer
      { x: 0.55, y: 0.55, z: 0.55, topColor: colors.skyBlue },
      { x: -0.55, y: 0.55, z: 0.55, topColor: colors.iceBlue },
      { x: 0.55, y: 0.55, z: -0.55, topColor: colors.skyBlue },
      { x: -0.55, y: 0.55, z: -0.55, topColor: colors.iceBlue },
    ];

    // Create blocks group
    const blocksGroup = new THREE.Group();
    scene.add(blocksGroup);
    
    const blockGeometry = new THREE.BoxGeometry(0.95, 0.95, 0.95);
    
    blockConfigs.forEach((config) => {
      const materials = [
        new THREE.MeshBasicMaterial({ color: colors.navy }),      // right (+X)
        new THREE.MeshBasicMaterial({ color: colors.steelBlue }), // left (-X)
        new THREE.MeshBasicMaterial({ color: config.topColor }),  // top (+Y)
        new THREE.MeshBasicMaterial({ color: colors.navy }),      // bottom (-Y)
        new THREE.MeshBasicMaterial({ color: colors.steelBlue }), // front (+Z)
        new THREE.MeshBasicMaterial({ color: colors.navy }),      // back (-Z)
      ];
      
      const block = new THREE.Mesh(blockGeometry, materials);
      block.position.set(config.x, config.y, config.z); // Final position (no animation)
      blocksGroup.add(block);
    });

    // Create letters using simple plane geometry with canvas textures
    function createLetterTexture(letter: string, width: number, height: number): THREE.CanvasTexture {
      const canvas = document.createElement('canvas');
      canvas.width = width;
      canvas.height = height;
      const ctx = canvas.getContext('2d')!;
      
      // Clear with transparent background
      ctx.clearRect(0, 0, width, height);
      
      // Draw white letter with shadow for visibility
      ctx.fillStyle = '#FFFFFF';
      ctx.font = `bold ${height * 0.8}px Arial, sans-serif`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      
      // Add shadow for depth
      ctx.shadowColor = 'rgba(0, 0, 0, 0.3)';
      ctx.shadowBlur = 4;
      ctx.shadowOffsetX = 2;
      ctx.shadowOffsetY = 2;
      
      ctx.fillText(letter, width / 2, height / 2);
      
      const texture = new THREE.CanvasTexture(canvas);
      texture.needsUpdate = true;
      return texture;
    }

    // H on left face (visible from isometric view) - positioned on -X face
    const hTexture = createLetterTexture('H', 256, 256);
    const hMaterial = new THREE.MeshBasicMaterial({ 
      map: hTexture, 
      transparent: true,
      side: THREE.DoubleSide,
      depthTest: false
    });
    const hPlane = new THREE.Mesh(new THREE.PlaneGeometry(1.8, 1.8), hMaterial);
    hPlane.position.set(-1.08, 0, 0);
    hPlane.rotation.y = -Math.PI / 2; // Face outward from left
    hPlane.renderOrder = 1;
    blocksGroup.add(hPlane);

    // X on right/back face (visible from isometric view) - positioned on -Z face  
    const xTexture = createLetterTexture('X', 256, 256);
    const xMaterial = new THREE.MeshBasicMaterial({ 
      map: xTexture, 
      transparent: true,
      side: THREE.DoubleSide,
      depthTest: false
    });
    const xPlane = new THREE.Mesh(new THREE.PlaneGeometry(1.8, 1.8), xMaterial);
    xPlane.position.set(0, 0, -1.08);
    xPlane.rotation.y = Math.PI; // Face outward from back
    xPlane.renderOrder = 1;
    blocksGroup.add(xPlane);

    // T on top face
    const tTexture = createLetterTexture('T', 256, 256);
    const tMaterial = new THREE.MeshBasicMaterial({ 
      map: tTexture, 
      transparent: true,
      side: THREE.DoubleSide,
      depthTest: false
    });
    const tPlane = new THREE.Mesh(new THREE.PlaneGeometry(1.8, 1.8), tMaterial);
    tPlane.position.set(0, 1.08, 0);
    tPlane.rotation.x = -Math.PI / 2; // Face upward
    tPlane.renderOrder = 1;
    blocksGroup.add(tPlane);

    // Render once (static)
    renderer.render(scene, camera);

    // Cleanup on page navigation
    document.addEventListener('astro:before-swap', () => {
      renderer.dispose();
    });
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHTXLogo);
  } else {
    initHTXLogo();
  }
  
  document.addEventListener('astro:page-load', initHTXLogo);
</script>
