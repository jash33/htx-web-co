  .hero__border-corner--top-left {
    top: 0;
    left: 0;
  }

  .hero__border-corner--top-right {
    top: 0;
    right: 0;
  }

  .hero__border-corner--bottom-left {
    bottom: 0;
    left: 0;
  }

  .hero__border-corner--bottom-right {
    bottom: 0;
    right: 0;
  }

