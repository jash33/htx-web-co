  /* =================================================================
   * MOCKUP GLOW & FLOATING ELEMENTS
   * =================================================================
   */
  .hero__mockup-glow {
    position: absolute;
    inset: -20%;
    background: radial-gradient(ellipse at center, rgba(54, 83, 149, 0.3) 0%, transparent 60%);
    z-index: -1;
    filter: blur(40px);
  }

  .hero__mockup-float {
    display: none; /* Hidden on mobile, shown with mockup on desktop */
    position: absolute;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    border-radius: var(--radius-lg);
    background: var(--color-background);
    box-shadow: var(--shadow-md);
    z-index: 10;
    border: var(--border-width-2) solid var(--color-border-dark);
  }

  .hero__mockup-float--1 {
    top: 20%;
    right: -175px;
    transform: rotate(3deg);
    animation: floatCardIn1 0.8s ease-out 0.6s backwards, float1 6s ease-in-out 1.4s infinite;
  }

  .hero__mockup-float--2 {
    bottom: 7%;
    right: -120px;
    transform: rotate(-3deg);
    animation: floatCardIn2 0.8s ease-out 0.8s backwards, float2 5s ease-in-out 1.6s infinite;
  }

  .hero__mockup-float--3 {
    top: 55%;
    left: -17%;
    transform: rotate(-2deg);
    animation: floatCardIn3 0.8s ease-out 1.0s backwards, float3 7s ease-in-out 1.8s infinite;
  }

  @keyframes floatCardIn1 {
    from {
      opacity: 0;
      transform: rotate(3deg) translateY(12px);
    }
    to {
      opacity: 1;
      transform: rotate(3deg) translateY(0);
    }
  }

  @keyframes floatCardIn2 {
    from {
      opacity: 0;
      transform: rotate(-3deg) translateY(12px);
    }
    to {
      opacity: 1;
      transform: rotate(-3deg) translateY(0);
    }
  }

  @keyframes floatCardIn3 {
    from {
      opacity: 0;
      transform: rotate(-2deg) translateY(12px);
    }
    to {
      opacity: 1;
      transform: rotate(-2deg) translateY(0);
    }
  }

  .hero__float-icon {
