  /* =================================================================
   * ANIMATED GRID BACKGROUND
   * =================================================================
   * A subtle, animated grid pattern that creates depth and tech aesthetic.
   * Features a pulsing glow effect that travels across the grid.
   * Uses CSS gradients for performance and GPU-accelerated animations.
   */

  .hero__grid-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    opacity: 0;
    display: none; /* Removed grid pattern for cleaner look */
  }

  .hero__grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.18) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.18) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: gridMove 8s linear infinite, gridPulse 2s ease-in-out infinite;
  }

  /* Glowing highlight that moves across the grid
   * Uses multiple layered gradients with staggered animations
   * for smoother, more organic movement */
  .hero__grid-glow {
    position: absolute;
    inset: 0;
  }

  /* Primary glow - moves in a smooth circular path */
  .hero__grid-glow::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 500px 350px at 50% 50%,
        rgba(91, 192, 196, 0.28) 0%,
        rgba(59, 130, 246, 0.18) 40%,
        transparent 70%
      );
    animation: gridGlowFloat1 12s ease-in-out infinite;
    opacity: 0.9;
  }

  /* Secondary glow - moves in opposite direction for depth */
  .hero__grid-glow::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 400px 300px at 50% 50%,
        rgba(99, 102, 241, 0.25) 0%,
        rgba(91, 192, 196, 0.15) 40%,
        transparent 70%
      );
    animation: gridGlowFloat2 15s ease-in-out infinite;
    opacity: 0.85;
  }

  @keyframes gridMove {
    0% {
      transform: translate(0, 0);
    }
    100% {
      transform: translate(50px, 50px);
    }
  }

  @keyframes gridPulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }

  /* Smooth circular motion for primary glow */
  @keyframes gridGlowFloat1 {
    0% {
      transform: translate(-20%, -15%);
    }
    25% {
      transform: translate(25%, -10%);
    }
    50% {
      transform: translate(20%, 20%);
    }
    75% {
      transform: translate(-15%, 15%);
    }
    100% {
      transform: translate(-20%, -15%);
    }
  }

  /* Counter-rotating motion for secondary glow */
  @keyframes gridGlowFloat2 {
    0% {
      transform: translate(15%, 20%);
    }
    33% {
      transform: translate(-20%, 5%);
    }
    66% {
      transform: translate(10%, -20%);
    }
    100% {
      transform: translate(15%, 20%);
    }
  }

  /* Responsive grid sizing */
  @media screen and (min-width: 640px) {
    .hero__grid-lines {
      background-size: 60px 60px;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.2) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.2) 1px, transparent 1px);
    }

    @keyframes gridMove {
      0% {
        transform: translate(0, 0);
      }
      100% {
        transform: translate(60px, 60px);
      }
    }
  }

  @media screen and (min-width: 1024px) {
    .hero__grid-bg {
      opacity: 0.85;
    }

    .hero__grid-lines {
      background-size: 80px 80px;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.22) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.22) 1px, transparent 1px);
    }

    @keyframes gridMove {
      0% {
        transform: translate(0, 0);
      }
      100% {
        transform: translate(80px, 80px);
      }
    }

    /* Larger glows on desktop */
    .hero__grid-glow::before {
      background:
        radial-gradient(
          ellipse 700px 450px at 50% 50%,
          rgba(91, 192, 196, 0.32) 0%,
          rgba(59, 130, 246, 0.2) 40%,
          transparent 70%
        );
    }

    .hero__grid-glow::after {
      background:
        radial-gradient(
          ellipse 550px 400px at 50% 50%,
          rgba(99, 102, 241, 0.28) 0%,
          rgba(91, 192, 196, 0.18) 40%,
          transparent 70%
        );
    }
  }

  /* =================================================================
   * FLOATING GRADIENT ORBS
   * =================================================================
   * Elegant, large gradient orbs that slowly float and pulse.
   * Creates a modern, calming tech aesthetic without distraction.
   * Uses GPU-accelerated transforms for smooth 60fps animation.
   */

  .hero__orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  /* Base orb styles - large, soft, blurred gradient circles */
  .hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.4;
    will-change: transform;
  }

  /* Orb 1 - Large purple/blue orb, top-left area */
  .hero__orb--1 {
    width: 400px;
    height: 400px;
    top: -10%;
    left: -5%;
    background: radial-gradient(
      circle,
      rgba(91, 192, 196, 0.6) 0%,
      rgba(99, 102, 241, 0.4) 40%,
      transparent 70%
    );
    animation: orbFloat1 20s ease-in-out infinite;
  }

  /* Orb 2 - Medium cyan/teal orb, right side */
  .hero__orb--2 {
    width: 300px;
    height: 300px;
    top: 20%;
    right: -5%;
    background: radial-gradient(
      circle,
      rgba(34, 211, 238, 0.5) 0%,
      rgba(59, 130, 246, 0.3) 50%,
      transparent 70%
    );
    animation: orbFloat2 25s ease-in-out infinite;
  }

  /* Orb 3 - Small bright accent orb, center-bottom */
  .hero__orb--3 {
    width: 200px;
    height: 200px;
    bottom: 10%;
    left: 30%;
    background: radial-gradient(
      circle,
      rgba(167, 139, 250, 0.5) 0%,
      rgba(91, 192, 196, 0.3) 50%,
      transparent 70%
    );
    animation: orbFloat3 18s ease-in-out infinite;
  }

  /* Orb 4 - Large soft orb, bottom-right */
  .hero__orb--4 {
    width: 350px;
    height: 350px;
    bottom: -15%;
    right: 10%;
    background: radial-gradient(
      circle,
      rgba(99, 102, 241, 0.4) 0%,
      rgba(91, 192, 196, 0.2) 50%,
      transparent 70%
    );
    animation: orbFloat4 22s ease-in-out infinite;
  }

  /* Orb 5 - Extra subtle orb for depth, mid-left */
  .hero__orb--5 {
    width: 250px;
    height: 250px;
    top: 50%;
    left: 5%;
    background: radial-gradient(
      circle,
      rgba(59, 130, 246, 0.35) 0%,
