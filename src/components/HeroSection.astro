  /* =================================================================
   * CAROUSEL & STACKED CARDS
   * =================================================================
   */
  .hero__carousel {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hero__carousel-card {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }

  /* Stacked card positions */
  .hero__carousel-card[data-card="0"] {
    z-index: 3;
    transform: rotate(-2deg) translateY(0);
  }

  .hero__carousel-card[data-card="1"] {
    z-index: 2;
    transform: rotate(1deg) translateX(15px) translateY(8px);
  }

  .hero__carousel-card[data-card="2"] {
    z-index: 1;
    transform: rotate(3deg) translateX(30px) translateY(16px);
  }

  /* Active card comes to front */
  .hero__carousel-card--active {
    z-index: 10 !important;
    transform: rotate(0deg) translateX(0) translateY(0) !important;
  }

  /* Non-active cards shift back */
  .hero__carousel-card:not(.hero__carousel-card--active) {
    opacity: 0.7;
    filter: brightness(0.9);
  }

  /* Carousel navigation dots */
  .hero__carousel-nav {
    position: absolute;
    bottom: -35px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 20;
  }

  .hero__carousel-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.5);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .hero__carousel-dot:hover {
    border-color: rgba(255, 255, 255, 0.8);
    background: rgba(255, 255, 255, 0.2);
  }

  .hero__carousel-dot--active {
    background: white;
    border-color: white;
  }

