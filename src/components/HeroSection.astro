</style>

<script>
  function initMockupCarousel() {
    const carousel = document.querySelector('.hero__carousel');
    if (!carousel) return;

    const cards = carousel.querySelectorAll('.hero__carousel-card');
    const dots = carousel.querySelectorAll('.hero__carousel-dot');
    let currentIndex = 0;

    function showCard(index: number) {
      // Update cards
      cards.forEach((card, i) => {
        card.classList.remove('hero__carousel-card--active');
        if (i === index) {
          card.classList.add('hero__carousel-card--active');
        }
      });

      // Update dots
      dots.forEach((dot, i) => {
        dot.classList.remove('hero__carousel-dot--active');
        if (i === index) {
          dot.classList.add('hero__carousel-dot--active');
        }
      });

      currentIndex = index;
    }

    // Click on dots
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => showCard(index));
    });

    // Click on cards to bring to front
    cards.forEach((card, index) => {
      card.addEventListener('click', () => {
        if (!card.classList.contains('hero__carousel-card--active')) {
          showCard(index);
        }
      });
    });

    // Auto-rotate every 5 seconds
    setInterval(() => {
      const nextIndex = (currentIndex + 1) % cards.length;
      showCard(nextIndex);
    }, 5000);
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMockupCarousel);
  } else {
    initMockupCarousel();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initMockupCarousel);
</script>
