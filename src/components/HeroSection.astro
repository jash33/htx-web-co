  .hero__border-line--top,
  .hero__border-line--bottom {
    left: 50px;
    right: 50px;
    height: 1px;
  }

  .hero__border-line--top {
    top: 0;
  }

  .hero__border-line--bottom {
    bottom: 0;
  }

  .hero__border-line--left,
  .hero__border-line--right {
    top: 50px;
    bottom: 50px;
    width: 1px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(255, 255, 255, 0.15) 10%,
      rgba(255, 255, 255, 0.4) 50%,
      rgba(255, 255, 255, 0.15) 90%,
