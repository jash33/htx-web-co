    100% { background-position: 0% 50%; }
  }

  /* Subtle overlay pulse for depth perception */
  @keyframes heroOverlayPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  @keyframes mockupSlideIn {
    from {
      opacity: 0;
      transform: translateX(40px) perspective(1000px) rotateY(-5deg) rotateX(2deg);
    }
    to {
      opacity: 1;
      transform: translateX(0) perspective(1000px) rotateY(-5deg) rotateX(2deg);
    }
  }

  @keyframes accentFloat {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-20px, 20px); }
