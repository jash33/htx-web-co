---
/**
 * ServiceCard Component
 * A card component for displaying a single service offering with icon,
 * title, description, and optional call-to-action.
 *
 * Features:
 * - Icon/visual element display
 * - Clear service title
 * - Brief description (2-3 sentences)
 * - Optional 'Learn More' CTA link/button
 * - Hover animations for enhanced interactivity
 * - Accessible with proper heading hierarchy
 * - Touch-friendly target sizes on mobile
 *
 * @example Basic usage
 * ```astro
 * <ServiceCard
 *   id="web-design"
 *   title="Website Design"
 *   description="Custom, responsive websites tailored to your business."
 * />
 * ```
 *
 * @example With icon and CTA
 * ```astro
 * <ServiceCard
 *   id="web-design"
 *   title="Website Design"
 *   description="Custom, responsive websites tailored to your business."
 *   icon="<svg>...</svg>"
 *   cta={{ text: 'Learn More', href: '/services/web-design' }}
 * />
 * ```
 */

import type { ServiceCardProps } from '../types/service';
import Button from './Button.astro';

interface Props extends ServiceCardProps {}

const {
  id,
  title,
  description,
  icon,
  cta,
  class: className = '',
} = Astro.props;

// Build CSS classes
const cardClasses = [
  'service-card',
  className,
].filter(Boolean).join(' ');
---

<article class={cardClasses} id={`service-${id}`}>
  {icon && (
    <div class="service-card__icon" aria-hidden="true">
      <Fragment set:html={icon} />
    </div>
  )}

  <div class="service-card__content">
    <h3 class="service-card__title">{title}</h3>
    <p class="service-card__description">{description}</p>
  </div>

  {cta && (
    <div class="service-card__footer">
      <Button
        text={cta.text}
        href={cta.href}
        variant="secondary"
        size="small"
        openInNewTab={cta.openInNewTab}
        class="service-card__cta"
      />
    </div>
  )}
</article>

<style>
  /* =================================================================
   * SERVICE CARD COMPONENT STYLES
   * =================================================================
   * Uses design system variables from variables.css
   * Follows BEM naming convention for maintainability
   */

  .service-card {
    /* Layout */
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);

    /* Box model */
    padding: var(--spacing-6);
    min-width: 0; /* Prevent overflow in grid */
    min-height: 280px; /* Ensure cards have minimum height for content */

    /* Positioning for pseudo-elements */
    position: relative;

    /* Visual */
    background-color: var(--color-background-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);

    /* Overflow for shine effect */
    overflow: hidden;

    /* Animation - smooth sequential highlight effect */
    transition:
      box-shadow var(--duration-300) var(--ease-smooth),
      transform var(--duration-300) var(--ease-smooth),
      border-color var(--duration-300) var(--ease-smooth);
  }

  /* Gradient border glow effect - appears on hover */
  .service-card::before {
    content: '';
    position: absolute;
    inset: -2px;
    background: linear-gradient(
      135deg,
      var(--color-primary-400) 0%,
      var(--color-accent) 50%,
      var(--color-accent-alt) 100%
    );
    border-radius: calc(var(--radius-xl) + 2px);
    opacity: 0;
    z-index: -1;
    filter: blur(8px);
    transition: opacity var(--duration-300) var(--ease-smooth);
  }

  /* Shine sweep effect */
  .service-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.08) 50%,
      transparent 100%
    );
    transform: skewX(-20deg);
    transition: left var(--duration-500) var(--ease-smooth);
    pointer-events: none;
  }

  /* Shimmer animation effect */
  @keyframes shimmer {
    0% {
      left: -100%;
    }
    100% {
      left: 150%;
    }
  }

  .service-card.service-card--shimmer::after {
    animation: shimmer 0.6s ease-out forwards;
    z-index: 1;
  }

  .service-card:hover,
  .service-card.service-card--highlight {
    box-shadow: var(--shadow-lg), var(--glow-card-hover);
    transform: translateY(-6px);
    border-color: var(--color-primary-300);
  }

  .service-card:hover::before,
  .service-card.service-card--highlight::before {
    opacity: 0.35;
  }

  .service-card:hover::after,
  .service-card.service-card--highlight::after {
    left: 150%;
  }

  /* Icon Container */
  .service-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--spacing-14);
    height: var(--spacing-14);
    background: linear-gradient(
      135deg,
      var(--color-primary-50) 0%,
      var(--color-primary-100) 100%
    );
    border-radius: var(--radius-lg);
    color: var(--color-primary);
    position: relative;
    transition:
      background var(--duration-300) var(--ease-smooth),
      transform var(--duration-300) var(--ease-smooth),
      box-shadow var(--duration-300) var(--ease-smooth);
  }

  .service-card:hover .service-card__icon,
  .service-card.service-card--highlight .service-card__icon {
    background: linear-gradient(
      135deg,
      var(--color-primary-100) 0%,
      var(--color-primary-200) 100%
    );
    transform: scale(1.08) rotate(3deg);
    box-shadow: var(--glow-primary-sm);
  }

  .service-card__icon :global(svg) {
    width: var(--spacing-7);
    height: var(--spacing-7);
    transition: transform var(--duration-300) var(--ease-smooth);
  }

  .service-card:hover .service-card__icon :global(svg),
  .service-card.service-card--highlight .service-card__icon :global(svg) {
    transform: scale(1.05);
  }

  /* Content Area */
  .service-card__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    flex: 1;
  }

  .service-card__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin: 0;
    line-height: var(--line-height-tight);
    transition: color var(--duration-300) var(--ease-smooth);
  }

  .service-card:hover .service-card__title {
    color: var(--color-primary);
  }

  .service-card__description {
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin: 0;
    transition: color var(--duration-300) var(--ease-smooth);
    /* Limit description height to prevent card overflow */
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .service-card:hover .service-card__description {
    color: var(--color-text-primary);
  }

  /* Footer with CTA */
  .service-card__footer {
    margin-top: auto;
    padding-top: var(--spacing-4);
  }

  /* =================================================================
   * RESPONSIVE STYLES
   * =================================================================
   */

  /* Tablet and up (768px) */
  @media screen and (min-width: 768px) {
    .service-card {
      padding: var(--spacing-5);
      gap: var(--spacing-3);
      min-height: 260px;
    }

    .service-card__icon {
      width: var(--spacing-12);
      height: var(--spacing-12);
    }

    .service-card__icon :global(svg) {
      width: var(--spacing-6);
      height: var(--spacing-6);
    }

    .service-card__title {
      font-size: var(--font-size-lg);
    }

    .service-card__description {
      font-size: var(--font-size-sm);
      -webkit-line-clamp: 5;
    }
  }

  /* Desktop and up (1024px) */
  @media screen and (min-width: 1024px) {
    .service-card {
      padding: var(--spacing-6);
      gap: var(--spacing-4);
      min-height: 280px;
    }

    .service-card__icon {
      width: var(--spacing-14);
      height: var(--spacing-14);
    }

    .service-card__icon :global(svg) {
      width: var(--spacing-7);
      height: var(--spacing-7);
    }

    .service-card__title {
      font-size: var(--font-size-xl);
    }

    .service-card__description {
      font-size: var(--font-size-sm);
      -webkit-line-clamp: 4;
    }
  }

  /* Large Desktop (1280px) - for 4+ column layouts */
  @media screen and (min-width: 1280px) {
    .service-card {
      min-height: 300px;
    }

    .service-card__description {
      -webkit-line-clamp: 5;
    }
  }

  /* Extra Large Desktop (1536px) - for 5 column layouts */
  @media screen and (min-width: 1536px) {
    .service-card {
      padding: var(--spacing-5);
      gap: var(--spacing-3);
      min-height: 320px;
    }

    .service-card__icon {
      width: var(--spacing-12);
      height: var(--spacing-12);
    }

    .service-card__icon :global(svg) {
      width: var(--spacing-6);
      height: var(--spacing-6);
    }

    .service-card__title {
      font-size: var(--font-size-lg);
    }

    .service-card__description {
      font-size: var(--font-size-sm);
      -webkit-line-clamp: 6;
    }

    .service-card__footer {
      padding-top: var(--spacing-3);
    }
  }

  /* =================================================================
   * MOBILE IN-VIEW STATE (scroll-triggered hover effect)
   * =================================================================
   */
  @media screen and (max-width: 767px) {
    .service-card.service-card--in-view {
      box-shadow: var(--shadow-lg), var(--glow-card-hover);
      transform: translateY(-6px);
      border-color: var(--color-primary-300);
    }

    .service-card.service-card--in-view::before {
      opacity: 0.35;
    }

    .service-card.service-card--in-view .service-card__icon {
      background: linear-gradient(
        135deg,
        var(--color-primary-100) 0%,
        var(--color-primary-200) 100%
      );
      transform: scale(1.08) rotate(3deg);
      box-shadow: var(--glow-primary-sm);
    }

    .service-card.service-card--in-view .service-card__title {
      color: var(--color-primary);
    }

    .service-card.service-card--in-view .service-card__description {
      color: var(--color-text-primary);
    }
  }

  /* =================================================================
   * REDUCED MOTION
   * Respect user preferences for reduced motion
   * =================================================================
   */
  @media (prefers-reduced-motion: reduce) {
    .service-card,
    .service-card__icon,
    .service-card__title,
    .service-card__description,
    .service-card__icon :global(svg) {
      transition: none;
    }

    .service-card::before,
    .service-card::after {
      display: none;
    }

    .service-card:hover {
      transform: none;
      /* Keep subtle visual feedback without motion */
      box-shadow: var(--shadow-lg);
    }

    .service-card:hover .service-card__icon {
      transform: none;
      box-shadow: none;
    }

    .service-card:hover .service-card__icon :global(svg) {
      transform: none;
    }
  }

  /* =================================================================
   * PRINT STYLES
   * =================================================================
   */
  @media print {
    .service-card {
      box-shadow: none;
      border: 1px solid var(--color-border);
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .service-card:hover {
      transform: none;
      box-shadow: none;
    }

    .service-card__footer {
      display: none;
    }
  }
</style>

<script>
  // Mobile scroll-triggered hover effect for service cards
  // Only ONE card can be highlighted at a time
  function initServiceCardInView() {
    // Only run on mobile
    if (window.innerWidth >= 768) return;

    const cards = document.querySelectorAll('.service-card');
    if (!cards.length) return;

    let activeCard: Element | null = null;

    const observer = new IntersectionObserver(
      (entries) => {
        // Find the card closest to the center of the viewport
        let bestCandidate: Element | null = null;
        let bestDistance = Infinity;
        const viewportCenter = window.innerHeight / 2;

        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const rect = entry.boundingClientRect;
            const cardCenter = rect.top + rect.height / 2;
            const distance = Math.abs(cardCenter - viewportCenter);
            
            if (distance < bestDistance) {
              bestDistance = distance;
              bestCandidate = entry.target;
            }
          }
        });

        // Also check currently visible cards not in this batch
        cards.forEach((card) => {
          const rect = card.getBoundingClientRect();
          const cardCenter = rect.top + rect.height / 2;
          const inTriggerZone = cardCenter > viewportCenter - 100 && cardCenter < viewportCenter + 100;
          
          if (inTriggerZone) {
            const distance = Math.abs(cardCenter - viewportCenter);
            if (distance < bestDistance) {
              bestDistance = distance;
              bestCandidate = card;
            }
          }
        });

        // Update active card - only one at a time
        if (bestCandidate && bestCandidate !== activeCard) {
          // Remove from previous
          if (activeCard) {
            activeCard.classList.remove('service-card--in-view');
          }
          // Add to new
          bestCandidate.classList.add('service-card--in-view');
          activeCard = bestCandidate;
        } else if (!bestCandidate && activeCard) {
          // No card in zone, remove highlight
          activeCard.classList.remove('service-card--in-view');
          activeCard = null;
        }
      },
      {
        root: null,
        rootMargin: '-40% 0px -40% 0px', // Trigger only in middle 20% of viewport
        threshold: [0, 0.5, 1],
      }
    );

    cards.forEach((card) => observer.observe(card));
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initServiceCardInView);
  } else {
    initServiceCardInView();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initServiceCardInView);
</script>
