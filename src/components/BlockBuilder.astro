---
/**
 * BlockBuilder Component
 * Animated isometric 3D blocks that assemble quickly
 * Matches the HTX Web Co. logo style
 */

interface Props {
  size?: 'small' | 'medium' | 'large';
  loop?: boolean;
  class?: string;
}

const {
  size = 'medium',
  loop = true,
  class: className = '',
} = Astro.props;

const sizeMap = { small: 24, medium: 36, large: 52 };
const blockSize = sizeMap[size];
---

<div class={`block-builder block-builder--${size} ${loop ? 'block-builder--loop' : ''} ${className}`}>
  <svg viewBox="0 0 200 220" class="block-builder__svg">
    <defs>
      <!-- Block template -->
      <g id="cube">
        <!-- Top face (brightest - aqua) -->
        <polygon class="cube-top" points="30,0 60,17 30,34 0,17" />
        <!-- Left face (medium - teal) -->
        <polygon class="cube-left" points="0,17 30,34 30,68 0,51" />
        <!-- Right face (darkest - midnight) -->
        <polygon class="cube-right" points="30,34 60,17 60,51 30,68" />
      </g>
    </defs>

    <!-- Layer 0 (bottom) -->
    <use href="#cube" class="block block--1" transform="translate(70, 120)" style="--delay: 0" />
    <use href="#cube" class="block block--2" transform="translate(100, 137)" style="--delay: 1" />
    <use href="#cube" class="block block--3" transform="translate(40, 137)" style="--delay: 2" />
    <use href="#cube" class="block block--4" transform="translate(70, 154)" style="--delay: 3" />

    <!-- Layer 1 -->
    <use href="#cube" class="block block--5" transform="translate(70, 86)" style="--delay: 4" />
    <use href="#cube" class="block block--6" transform="translate(100, 103)" style="--delay: 5" />
    <use href="#cube" class="block block--7" transform="translate(40, 103)" style="--delay: 6" />

    <!-- Layer 2 -->
    <use href="#cube" class="block block--8" transform="translate(70, 52)" style="--delay: 7" />
    <use href="#cube" class="block block--9" transform="translate(100, 69)" style="--delay: 8" />

    <!-- Layer 3 (top) -->
    <use href="#cube" class="block block--10" transform="translate(70, 18)" style="--delay: 9" />
  </svg>
</div>

<style>
  .block-builder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .block-builder--small .block-builder__svg {
    width: 100px;
    height: 110px;
  }

  .block-builder--medium .block-builder__svg {
    width: 150px;
    height: 165px;
  }

  .block-builder--large .block-builder__svg {
    width: 220px;
    height: 242px;
  }

  .block-builder__svg {
    overflow: visible;
  }

  /* Cube faces with brand colors */
  .cube-top {
    fill: #33D6B5;
  }

  .cube-left {
    fill: #015B77;
  }

  .cube-right {
    fill: #011F4B;
  }

  /* Color variations */
  .block--2 .cube-top,
  .block--5 .cube-top,
  .block--9 .cube-top {
    fill: #5EEBD0;
  }

  .block--2 .cube-left,
  .block--5 .cube-left,
  .block--9 .cube-left {
    fill: #0288a0;
  }

  .block--2 .cube-right,
  .block--5 .cube-right,
  .block--9 .cube-right {
    fill: #013a6b;
  }

  .block--3 .cube-top,
  .block--6 .cube-top {
    fill: #28c9a7;
  }

  .block--3 .cube-left,
  .block--6 .cube-left {
    fill: #014d65;
  }

  .block--3 .cube-right,
  .block--6 .cube-right {
    fill: #011a3d;
  }

  /* Animation */
  .block {
    opacity: 0;
    animation: blockDrop 0.25s ease-out forwards;
    animation-delay: calc(var(--delay) * 0.07s);
  }

  @keyframes blockDrop {
    0% {
      opacity: 0;
      transform: translateY(-40px);
    }
    70% {
      opacity: 1;
      transform: translateY(3px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Looping animation */
  .block-builder--loop .block {
    animation: blockDropLoop 2.5s ease-in-out infinite;
    animation-delay: calc(var(--delay) * 0.07s);
  }

  @keyframes blockDropLoop {
    0%, 8% {
      opacity: 0;
      transform: translateY(-40px);
    }
    18% {
      opacity: 1;
      transform: translateY(3px);
    }
    22%, 65% {
      opacity: 1;
      transform: translateY(0);
    }
    80%, 100% {
      opacity: 0;
      transform: translateY(-20px);
    }
  }

  /* Subtle hover interaction */
  .block-builder:hover .block {
    animation-play-state: running;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .block {
      animation: none;
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
