---
/**
 * BlockBuilder Component
 * Three.js rotating isometric blocks
 */

interface Props {
  size?: 'small' | 'medium' | 'large';
  class?: string;
}

const {
  size = 'medium',
  class: className = '',
} = Astro.props;

const sizeMap = { small: 200, medium: 300, large: 400 };
const canvasSize = sizeMap[size];
---

<div class={`block-builder block-builder--${size} ${className}`}>
  <canvas id="block-canvas" width={canvasSize} height={canvasSize}></canvas>
</div>

<style>
  .block-builder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #block-canvas {
    display: block;
  }

  .block-builder--small #block-canvas {
    width: 200px;
    height: 200px;
  }

  .block-builder--medium #block-canvas {
    width: 300px;
    height: 300px;
  }

  .block-builder--large #block-canvas {
    width: 400px;
    height: 400px;
  }
</style>

<script>
  import * as THREE from 'three';

  function initBlockBuilder() {
    const canvas = document.getElementById('block-canvas') as HTMLCanvasElement;
    if (!canvas || canvas.dataset.initialized) return;
    canvas.dataset.initialized = 'true';

    // Scene setup
    const scene = new THREE.Scene();
    
    // Isometric-style camera
    const aspect = 1;
    const frustumSize = 5;
    const camera = new THREE.OrthographicCamera(
      -frustumSize * aspect / 2,
      frustumSize * aspect / 2,
      frustumSize / 2,
      -frustumSize / 2,
      0.1,
      100
    );
    camera.position.set(5, 5, 5);
    camera.lookAt(0, 0, 0);

    // Renderer
    const renderer = new THREE.WebGLRenderer({ 
      canvas, 
      alpha: true,
      antialias: true 
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    // Brand colors
    const colors = {
      aqua: 0x33D6B5,
      aquaLight: 0x5EEBD0,
      teal: 0x015B77,
      midnight: 0x011F4B,
      midnightLight: 0x024a7a,
    };

    // Create blocks group
    const blocksGroup = new THREE.Group();
    scene.add(blocksGroup);

    // Block positions for pyramid (3 bottom, 1 top)
    const blockPositions = [
      { x: -0.6, y: 0, z: 0.6, color: colors.aqua },
      { x: 0.6, y: 0, z: 0.6, color: colors.aquaLight },
      { x: 0, y: 0, z: -0.5, color: colors.teal },
      { x: 0, y: 1, z: 0.2, color: colors.aqua },
    ];

    // Create blocks
    const blockGeometry = new THREE.BoxGeometry(0.9, 0.9, 0.9);
    
    blockPositions.forEach((pos, index) => {
      // Create materials for each face with gradient-like effect
      const materials = [
        new THREE.MeshBasicMaterial({ color: colors.midnight }), // right
        new THREE.MeshBasicMaterial({ color: colors.teal }), // left
        new THREE.MeshBasicMaterial({ color: pos.color }), // top
        new THREE.MeshBasicMaterial({ color: colors.midnight }), // bottom
        new THREE.MeshBasicMaterial({ color: colors.midnightLight }), // front
        new THREE.MeshBasicMaterial({ color: colors.teal }), // back
      ];
      
      const block = new THREE.Mesh(blockGeometry, materials);
      block.position.set(pos.x, pos.y, pos.z);
      
      // Store initial Y for drop animation
      block.userData.targetY = pos.y;
      block.userData.delay = index * 0.2;
      block.userData.dropped = false;
      block.position.y = pos.y + 5; // Start above
      block.scale.set(0, 0, 0); // Start invisible
      
      blocksGroup.add(block);
    });

    // Animation
    const clock = new THREE.Clock();
    let startTime = clock.getElapsedTime();

    function animate() {
      requestAnimationFrame(animate);
      
      const elapsed = clock.getElapsedTime();
      
      // Rotate the whole group
      blocksGroup.rotation.y = elapsed * 0.5;
      
      // Drop animation for each block
      blocksGroup.children.forEach((block) => {
        const mesh = block as THREE.Mesh;
        const delay = mesh.userData.delay;
        const dropTime = elapsed - startTime - delay;
        
        if (dropTime > 0 && dropTime < 1) {
          // Ease out bounce
          const t = Math.min(dropTime / 0.5, 1);
          const eased = 1 - Math.pow(1 - t, 3);
          
          mesh.position.y = mesh.userData.targetY + 5 * (1 - eased);
          mesh.scale.setScalar(Math.min(t * 2, 1));
        } else if (dropTime >= 1) {
          mesh.position.y = mesh.userData.targetY;
          mesh.scale.setScalar(1);
        }
      });

      renderer.render(scene, camera);
    }

    animate();

    // Cleanup on page navigation
    document.addEventListener('astro:before-swap', () => {
      renderer.dispose();
    });
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBlockBuilder);
  } else {
    initBlockBuilder();
  }
  
  document.addEventListener('astro:page-load', initBlockBuilder);
</script>
