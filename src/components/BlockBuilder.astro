---
/**
 * BlockBuilder Component
 * Three.js blocks falling into place - GameCube style
 */

interface Props {
  size?: 'small' | 'medium' | 'large';
  class?: string;
}

const {
  size = 'medium',
  class: className = '',
} = Astro.props;

const sizeMap = { small: 200, medium: 300, large: 400 };
const canvasSize = sizeMap[size];
---

<div class={`block-builder block-builder--${size} ${className}`}>
  <canvas id="block-canvas" width={canvasSize} height={canvasSize}></canvas>
</div>

<style>
  .block-builder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #block-canvas {
    display: block;
  }

  .block-builder--small #block-canvas {
    width: 200px;
    height: 200px;
  }

  .block-builder--medium #block-canvas {
    width: 300px;
    height: 300px;
  }

  .block-builder--large #block-canvas {
    width: 400px;
    height: 400px;
  }
</style>

<script>
  import * as THREE from 'three';

  function initBlockBuilder() {
    const canvas = document.getElementById('block-canvas') as HTMLCanvasElement;
    if (!canvas || canvas.dataset.initialized) return;
    canvas.dataset.initialized = 'true';

    // Scene setup
    const scene = new THREE.Scene();
    scene.background = null; // Transparent background
    
    // Isometric-style camera (fixed position, no rotation)
    const aspect = 1;
    const frustumSize = 6;
    const camera = new THREE.OrthographicCamera(
      -frustumSize * aspect / 2,
      frustumSize * aspect / 2,
      frustumSize / 2,
      -frustumSize / 2,
      0.1,
      100
    );
    camera.position.set(5, 4, 5);
    camera.lookAt(0, 0, 0);

    // Renderer
    const renderer = new THREE.WebGLRenderer({ 
      canvas, 
      antialias: true,
      alpha: true 
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Brand colors - Darker palette
    const colors = {
      steelBlue: 0x3A7CA8,    // Top faces
      mediumBlue: 0x4A90C4,   // Alternating tops
      navy: 0x1E4B6E,         // Left/front faces
      deepNavy: 0x14354F,     // Right/back faces
    };

    // Block positions - builds a 2x2 cube (centered at origin for proper rotation)
    const blockConfigs = [
      // Bottom layer - L-shape first
      { x: 0.55, y: -0.55, z: 0.55, topColor: colors.steelBlue, delay: 0 },         // corner block
      { x: -0.55, y: -0.55, z: 0.55, topColor: colors.mediumBlue, delay: 0.6 },     // extends left
      { x: 0.55, y: -0.55, z: -0.55, topColor: colors.steelBlue, delay: 1.2 },      // extends back
      { x: -0.55, y: -0.55, z: -0.55, topColor: colors.mediumBlue, delay: 1.8 },    // completes bottom
      
      // Top layer
      { x: 0.55, y: 0.55, z: 0.55, topColor: colors.steelBlue, delay: 2.4 },        // top corner
      { x: -0.55, y: 0.55, z: 0.55, topColor: colors.mediumBlue, delay: 3.0 },      // top left
      { x: 0.55, y: 0.55, z: -0.55, topColor: colors.steelBlue, delay: 3.6 },       // top back
      { x: -0.55, y: 0.55, z: -0.55, topColor: colors.mediumBlue, delay: 4.2 },     // top final
    ];

    // Create blocks group for rotation (cube is centered at origin)
    const blocksGroup = new THREE.Group();
    scene.add(blocksGroup);
    
    const blocks: THREE.Mesh[] = [];
    const blockGeometry = new THREE.BoxGeometry(0.95, 0.95, 0.95);
    
    blockConfigs.forEach((config) => {
      const materials = [
        new THREE.MeshBasicMaterial({ color: colors.deepNavy }), // right
        new THREE.MeshBasicMaterial({ color: colors.navy }),     // left
        new THREE.MeshBasicMaterial({ color: config.topColor }), // top
        new THREE.MeshBasicMaterial({ color: colors.deepNavy }), // bottom
        new THREE.MeshBasicMaterial({ color: colors.navy }),     // front
        new THREE.MeshBasicMaterial({ color: colors.deepNavy }), // back
      ];
      
      const block = new THREE.Mesh(blockGeometry, materials);
      block.position.set(config.x, config.y + 6, config.z); // Start above
      
      block.userData.targetY = config.y;
      block.userData.delay = config.delay;
      block.userData.startTime = null;
      
      blocksGroup.add(block);
      blocks.push(block);
    });

    // Easing functions
    function easeOutCubic(t: number): number {
      return 1 - Math.pow(1 - t, 3);
    }
    
    function easeInOutQuad(t: number): number {
      return t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
    }
    
    // Animation timing - slower and smoother
    const clock = new THREE.Clock();
    const animationDuration = 1.2; // seconds per block drop
    const spinDuration = 1.8; // seconds for spin
    const liftHeight = 0.8; // how high the cube lifts
    const loopDelay = 1.2; // seconds to wait before looping
    let loopStartTime = 0;
    let animationStarted = false;
    let isInView = false;

    // Check if this is the navbar version (small size, inside header)
    const isInNavbar = canvas.closest('.header__animation') !== null;
    
    // Navbar version starts immediately; others wait for visibility
    if (isInNavbar) {
      animationStarted = true;
      isInView = true;
      clock.start();
    } else {
      // Wait until fully in view before starting animation
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && entry.intersectionRatio >= 0.95) {
              isInView = true;
              if (!animationStarted) {
                animationStarted = true;
                clock.start();
              }
            } else {
              isInView = false;
            }
          });
        },
        { threshold: [0.95, 1.0] }
      );
      observer.observe(canvas);
    }

    function animate() {
      requestAnimationFrame(animate);
      
      // Don't animate until in view
      if (!animationStarted) {
        renderer.render(scene, camera);
        return;
      }
      
      const elapsed = clock.getElapsedTime();
      const loopElapsed = elapsed - loopStartTime;
      
      // Timeline - spin includes the full arc (up and down with bounce)
      const lastBlockEndTime = blockConfigs[blockConfigs.length - 1].delay + animationDuration;
      const spinStartTime = lastBlockEndTime;
      const totalSpinArc = spinDuration + 1.0; // Spin + landing with bounce (slower, smoother)
      const spinEndTime = spinStartTime + totalSpinArc;
      const totalCycleTime = spinEndTime + loopDelay;
      
      // Check if we should reset (loop)
      if (loopElapsed > totalCycleTime) {
        loopStartTime = elapsed;
        blocks.forEach((block) => {
          block.position.y = block.userData.targetY + 6;
        });
        blocksGroup.rotation.y = 0;
        blocksGroup.position.y = 0;
        blocksGroup.scale.setScalar(1);
        return;
      }
      
      // Spin + arc phase (continuous motion)
      if (loopElapsed > spinStartTime && loopElapsed < spinEndTime) {
        const arcProgress = (loopElapsed - spinStartTime) / totalSpinArc;
        
        // Rotation: complete faster (in first 50% of arc), then hold
        const rotationComplete = 0.5; // Complete rotation by this point in the arc
        const rotationProgress = Math.min(arcProgress / rotationComplete, 1);
        const rotationEased = easeOutCubic(rotationProgress);
        blocksGroup.rotation.y = rotationEased * Math.PI * 2;
        
        // Scale: shrink during rotation, expand back as it finishes
        const minScale = 0.75;
        let scale: number;
        if (rotationProgress < 0.5) {
          // Shrinking phase (first half of rotation)
          const shrinkProgress = rotationProgress / 0.5;
          scale = 1 - (1 - minScale) * easeOutCubic(shrinkProgress);
        } else {
          // Expanding phase (second half of rotation)
          const expandProgress = (rotationProgress - 0.5) / 0.5;
          scale = minScale + (1 - minScale) * easeOutCubic(expandProgress);
        }
        blocksGroup.scale.setScalar(scale);
        
        // Height: quick rise, fast fall, then bounces
        const peakPoint = 0.25; // Peak earlier
        let height: number;
        
        if (arcProgress < peakPoint) {
          // Rising phase - smooth ease up
          const riseProgress = arcProgress / peakPoint;
          height = easeOutCubic(riseProgress) * liftHeight;
        } else if (arcProgress < 0.5) {
          // Fast falling phase (before landing)
          const fallProgress = (arcProgress - peakPoint) / (0.5 - peakPoint);
          const fallCurve = fallProgress * fallProgress * fallProgress; // Cubic fall (faster)
          height = liftHeight * (1 - fallCurve);
        } else {
          // Bounce phase - cube has "landed", now bouncing
          const bounceProgress = (arcProgress - 0.5) / 0.5;
          // Damped bounces
          const bounceCount = 2;
          const damping = Math.pow(1 - bounceProgress, 1.5);
          const bounceWave = Math.abs(Math.sin(bounceProgress * Math.PI * bounceCount));
          height = bounceWave * damping * liftHeight * 0.4; // 40% of original height for first bounce
        }
        
        blocksGroup.position.y = height;
      }
      // Settled
      else if (loopElapsed >= spinEndTime) {
        blocksGroup.rotation.y = Math.PI * 2;
        blocksGroup.position.y = 0;
        blocksGroup.scale.setScalar(1);
      }
      
      // Animate each block dropping in
      blocks.forEach((block, index) => {
        const config = blockConfigs[index];
        const blockTime = loopElapsed - config.delay;
        
        if (blockTime > 0 && blockTime < animationDuration) {
          const t = blockTime / animationDuration;
          const eased = easeOutCubic(t);
          const startY = block.userData.targetY + 6;
          block.position.y = startY - (startY - block.userData.targetY) * eased;
        } else if (blockTime >= animationDuration) {
          block.position.y = block.userData.targetY;
        }
      });

      renderer.render(scene, camera);
    }

    animate();

    // Click handling - change block colors on click
    const raycaster = new THREE.Raycaster();
    const mouse = new THREE.Vector2();
    
    // Color palette for random selection
    const clickColors = [
      0xFF6B6B, // coral red
      0xFFE66D, // yellow
      0x95E1D3, // mint
      0xF38181, // salmon
      0xAA96DA, // lavender
      0xFCBAD3, // pink
      0x67ACE0, // sky blue (brand primary)
      0xB5D8F0, // ice blue (brand light)
      0x4A90C4, // steel blue (brand medium)
    ];
    
    function onCanvasClick(event: MouseEvent) {
      const rect = canvas.getBoundingClientRect();
      mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
      mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
      
      raycaster.setFromCamera(mouse, camera);
      const intersects = raycaster.intersectObjects(blocks);
      
      if (intersects.length > 0) {
        const clickedBlock = intersects[0].object as THREE.Mesh;
        const materials = clickedBlock.material as THREE.MeshBasicMaterial[];
        
        // Pick a random color from the palette
        const newColor = clickColors[Math.floor(Math.random() * clickColors.length)];
        
        // Change all faces to variations of the new color
        materials.forEach((mat, i) => {
          if (i === 2) {
            // Top face - brightest
            mat.color.setHex(newColor);
          } else if (i === 1 || i === 4) {
            // Left/front faces - medium
            const color = new THREE.Color(newColor);
            color.multiplyScalar(0.7);
            mat.color.copy(color);
          } else {
            // Other faces - darkest
            const color = new THREE.Color(newColor);
            color.multiplyScalar(0.4);
            mat.color.copy(color);
          }
        });
      }
    }
    
    canvas.addEventListener('click', onCanvasClick);
    canvas.style.cursor = 'pointer';

    // Cleanup on page navigation
    document.addEventListener('astro:before-swap', () => {
      canvas.removeEventListener('click', onCanvasClick);
      renderer.dispose();
    });
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBlockBuilder);
  } else {
    initBlockBuilder();
  }
  
  document.addEventListener('astro:page-load', initBlockBuilder);
</script>
