---
/**
 * BlockBuilder Component
 * Three.js blocks falling into place - GameCube style
 */

interface Props {
  size?: 'small' | 'medium' | 'large';
  class?: string;
}

const {
  size = 'medium',
  class: className = '',
} = Astro.props;

const sizeMap = { small: 200, medium: 300, large: 400 };
const canvasSize = sizeMap[size];
---

<div class={`block-builder block-builder--${size} ${className}`}>
  <canvas id="block-canvas" width={canvasSize} height={canvasSize}></canvas>
</div>

<style>
  .block-builder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #block-canvas {
    display: block;
  }

  .block-builder--small #block-canvas {
    width: 200px;
    height: 200px;
  }

  .block-builder--medium #block-canvas {
    width: 300px;
    height: 300px;
  }

  .block-builder--large #block-canvas {
    width: 400px;
    height: 400px;
  }
</style>

<script>
  import * as THREE from 'three';

  function initBlockBuilder() {
    const canvas = document.getElementById('block-canvas') as HTMLCanvasElement;
    if (!canvas || canvas.dataset.initialized) return;
    canvas.dataset.initialized = 'true';

    // Scene setup
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0xffffff); // White background
    
    // Isometric-style camera (fixed position, no rotation)
    const aspect = 1;
    const frustumSize = 6;
    const camera = new THREE.OrthographicCamera(
      -frustumSize * aspect / 2,
      frustumSize * aspect / 2,
      frustumSize / 2,
      -frustumSize / 2,
      0.1,
      100
    );
    camera.position.set(5, 4, 5);
    camera.lookAt(0, 0, 0);

    // Renderer
    const renderer = new THREE.WebGLRenderer({ 
      canvas, 
      antialias: true 
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Brand colors
    const colors = {
      aqua: 0x33D6B5,
      aquaLight: 0x5EEBD0,
      teal: 0x015B77,
      midnight: 0x011F4B,
    };

    // Block positions - pyramid formation
    const blockConfigs = [
      // Bottom layer (3 blocks)
      { x: -0.55, y: 0, z: 0.55, topColor: colors.aqua, delay: 0 },
      { x: 0.55, y: 0, z: 0.55, topColor: colors.aquaLight, delay: 0.15 },
      { x: 0, y: 0, z: -0.45, topColor: colors.aqua, delay: 0.3 },
      // Top block
      { x: 0, y: 1, z: 0.2, topColor: colors.aquaLight, delay: 0.5 },
    ];

    // Create blocks
    const blocks: THREE.Mesh[] = [];
    const blockGeometry = new THREE.BoxGeometry(0.95, 0.95, 0.95);
    
    blockConfigs.forEach((config) => {
      const materials = [
        new THREE.MeshBasicMaterial({ color: colors.midnight }), // right
        new THREE.MeshBasicMaterial({ color: colors.teal }), // left
        new THREE.MeshBasicMaterial({ color: config.topColor }), // top
        new THREE.MeshBasicMaterial({ color: colors.midnight }), // bottom
        new THREE.MeshBasicMaterial({ color: colors.teal }), // front
        new THREE.MeshBasicMaterial({ color: colors.midnight }), // back
      ];
      
      const block = new THREE.Mesh(blockGeometry, materials);
      block.position.set(config.x, config.y + 8, config.z); // Start high above
      
      block.userData.targetY = config.y;
      block.userData.delay = config.delay;
      block.userData.startTime = null;
      
      scene.add(block);
      blocks.push(block);
    });

    // Easing function - bounce at end
    function easeOutBounce(t: number): number {
      if (t < 1 / 2.75) {
        return 7.5625 * t * t;
      } else if (t < 2 / 2.75) {
        t -= 1.5 / 2.75;
        return 7.5625 * t * t + 0.75;
      } else if (t < 2.5 / 2.75) {
        t -= 2.25 / 2.75;
        return 7.5625 * t * t + 0.9375;
      } else {
        t -= 2.625 / 2.75;
        return 7.5625 * t * t + 0.984375;
      }
    }

    // Animation
    const clock = new THREE.Clock();
    const animationDuration = 0.6; // seconds per block
    const loopDelay = 2; // seconds to wait before looping
    let loopStartTime = 0;

    function animate() {
      requestAnimationFrame(animate);
      
      const elapsed = clock.getElapsedTime();
      const loopElapsed = elapsed - loopStartTime;
      
      // Check if we should reset (loop)
      const lastBlockEndTime = blockConfigs[blockConfigs.length - 1].delay + animationDuration;
      if (loopElapsed > lastBlockEndTime + loopDelay) {
        // Reset all blocks
        loopStartTime = elapsed;
        blocks.forEach((block) => {
          block.position.y = block.userData.targetY + 8;
        });
        return;
      }
      
      // Animate each block
      blocks.forEach((block, index) => {
        const config = blockConfigs[index];
        const blockTime = loopElapsed - config.delay;
        
        if (blockTime > 0 && blockTime < animationDuration) {
          const t = blockTime / animationDuration;
          const eased = easeOutBounce(t);
          const startY = block.userData.targetY + 8;
          block.position.y = startY - (startY - block.userData.targetY) * eased;
        } else if (blockTime >= animationDuration) {
          block.position.y = block.userData.targetY;
        }
      });

      renderer.render(scene, camera);
    }

    animate();

    // Cleanup on page navigation
    document.addEventListener('astro:before-swap', () => {
      renderer.dispose();
    });
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBlockBuilder);
  } else {
    initBlockBuilder();
  }
  
  document.addEventListener('astro:page-load', initBlockBuilder);
</script>
