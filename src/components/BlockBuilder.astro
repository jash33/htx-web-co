---
/**
 * BlockBuilder Component
 * Animated isometric 3D blocks assembling in a row
 * Matches the HTX Web Co. logo style
 */

interface Props {
  size?: 'small' | 'medium' | 'large';
  blocks?: number;
  loop?: boolean;
  class?: string;
}

const {
  size = 'medium',
  blocks = 5,
  loop = true,
  class: className = '',
} = Astro.props;

const blockArray = Array.from({ length: blocks }, (_, i) => i);
---

<div class={`block-builder block-builder--${size} ${loop ? 'block-builder--loop' : ''} ${className}`}>
  <svg viewBox="0 0 320 120" class="block-builder__svg" preserveAspectRatio="xMidYMid meet">
    <defs>
      <!-- Isometric cube -->
      <g id="iso-cube">
        <!-- Top face (aqua) -->
        <polygon class="cube-top" points="25,0 50,14 25,28 0,14" />
        <!-- Left face (teal) -->
        <polygon class="cube-left" points="0,14 25,28 25,56 0,42" />
        <!-- Right face (midnight) -->
        <polygon class="cube-right" points="25,28 50,14 50,42 25,56" />
      </g>
    </defs>

    <!-- Row of blocks - positioned to form a clean row -->
    {blockArray.map((i) => (
      <use 
        href="#iso-cube" 
        class={`block block--${i + 1}`}
        transform={`translate(${35 + i * 50}, ${60 - i * 0})`}
        style={`--delay: ${i}`}
      />
    ))}
  </svg>
</div>

<style>
  .block-builder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .block-builder__svg {
    overflow: visible;
  }

  .block-builder--small .block-builder__svg {
    width: 200px;
    height: 80px;
  }

  .block-builder--medium .block-builder__svg {
    width: 300px;
    height: 110px;
  }

  .block-builder--large .block-builder__svg {
    width: 400px;
    height: 150px;
  }

  /* Cube faces with brand colors */
  .cube-top {
    fill: #33D6B5;
  }

  .cube-left {
    fill: #015B77;
  }

  .cube-right {
    fill: #011F4B;
  }

  /* Alternating colors for visual interest */
  .block--2 .cube-top,
  .block--4 .cube-top {
    fill: #5EEBD0;
  }
  .block--2 .cube-left,
  .block--4 .cube-left {
    fill: #0288a0;
  }
  .block--2 .cube-right,
  .block--4 .cube-right {
    fill: #013a6b;
  }

  .block--3 .cube-top,
  .block--5 .cube-top {
    fill: #28c9a7;
  }
  .block--3 .cube-left,
  .block--5 .cube-left {
    fill: #014d65;
  }
  .block--3 .cube-right,
  .block--5 .cube-right {
    fill: #011a3d;
  }

  /* Drop animation */
  .block {
    opacity: 0;
    animation: blockDrop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    animation-delay: calc(var(--delay) * 0.12s);
  }

  @keyframes blockDrop {
    0% {
      opacity: 0;
      transform: translateY(-60px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Looping version */
  .block-builder--loop .block {
    animation: blockDropLoop 3s ease-in-out infinite;
    animation-delay: calc(var(--delay) * 0.12s);
  }

  @keyframes blockDropLoop {
    0%, 5% {
      opacity: 0;
      transform: translateY(-60px);
    }
    15%, 20% {
      opacity: 1;
      transform: translateY(0);
    }
    25%, 70% {
      opacity: 1;
      transform: translateY(0);
    }
    85%, 100% {
      opacity: 0;
      transform: translateY(-40px);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .block {
      animation: none;
      opacity: 1;
    }
  }
</style>
