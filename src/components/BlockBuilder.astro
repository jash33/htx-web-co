---
/**
 * BlockBuilder Component
 * Three.js blocks falling into place - GameCube style
 */

interface Props {
  size?: 'small' | 'medium' | 'large';
  class?: string;
}

const {
  size = 'medium',
  class: className = '',
} = Astro.props;

const sizeMap = { small: 200, medium: 300, large: 400 };
const canvasSize = sizeMap[size];
---

<div class={`block-builder block-builder--${size} ${className}`}>
  <canvas id="block-canvas" width={canvasSize} height={canvasSize}></canvas>
</div>

<style>
  .block-builder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #block-canvas {
    display: block;
  }

  .block-builder--small #block-canvas {
    width: 200px;
    height: 200px;
  }

  .block-builder--medium #block-canvas {
    width: 300px;
    height: 300px;
  }

  .block-builder--large #block-canvas {
    width: 400px;
    height: 400px;
  }
</style>

<script>
  import * as THREE from 'three';

  function initBlockBuilder() {
    const canvas = document.getElementById('block-canvas') as HTMLCanvasElement;
    if (!canvas || canvas.dataset.initialized) return;
    canvas.dataset.initialized = 'true';

    // Scene setup
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0xffffff); // White background
    
    // Isometric-style camera (fixed position, no rotation)
    const aspect = 1;
    const frustumSize = 6;
    const camera = new THREE.OrthographicCamera(
      -frustumSize * aspect / 2,
      frustumSize * aspect / 2,
      frustumSize / 2,
      -frustumSize / 2,
      0.1,
      100
    );
    camera.position.set(5, 4, 5);
    camera.lookAt(0, 0, 0);

    // Renderer
    const renderer = new THREE.WebGLRenderer({ 
      canvas, 
      antialias: true 
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Brand colors
    const colors = {
      aqua: 0x33D6B5,
      aquaLight: 0x5EEBD0,
      teal: 0x015B77,
      midnight: 0x011F4B,
    };

    // Block positions - builds a 2x2 cube (centered at origin for proper rotation)
    const blockConfigs = [
      // Bottom layer - L-shape first
      { x: 0.55, y: -0.55, z: 0.55, topColor: colors.aqua, delay: 0 },             // corner block
      { x: -0.55, y: -0.55, z: 0.55, topColor: colors.aquaLight, delay: 0.5 },     // extends left
      { x: 0.55, y: -0.55, z: -0.55, topColor: colors.aqua, delay: 1.0 },          // extends back
      { x: -0.55, y: -0.55, z: -0.55, topColor: colors.aquaLight, delay: 1.5 },    // completes bottom
      
      // Top layer
      { x: 0.55, y: 0.55, z: 0.55, topColor: colors.aqua, delay: 2.0 },            // top corner
      { x: -0.55, y: 0.55, z: 0.55, topColor: colors.aquaLight, delay: 2.5 },      // top left
      { x: 0.55, y: 0.55, z: -0.55, topColor: colors.aqua, delay: 3.0 },           // top back
      { x: -0.55, y: 0.55, z: -0.55, topColor: colors.aquaLight, delay: 3.5 },     // top final
    ];

    // Create blocks group for rotation (cube is centered at origin)
    const blocksGroup = new THREE.Group();
    scene.add(blocksGroup);
    
    const blocks: THREE.Mesh[] = [];
    const blockGeometry = new THREE.BoxGeometry(0.95, 0.95, 0.95);
    
    blockConfigs.forEach((config) => {
      const materials = [
        new THREE.MeshBasicMaterial({ color: colors.midnight }), // right
        new THREE.MeshBasicMaterial({ color: colors.teal }), // left
        new THREE.MeshBasicMaterial({ color: config.topColor }), // top
        new THREE.MeshBasicMaterial({ color: colors.midnight }), // bottom
        new THREE.MeshBasicMaterial({ color: colors.teal }), // front
        new THREE.MeshBasicMaterial({ color: colors.midnight }), // back
      ];
      
      const block = new THREE.Mesh(blockGeometry, materials);
      block.position.set(config.x, config.y + 6, config.z); // Start above
      
      block.userData.targetY = config.y;
      block.userData.delay = config.delay;
      block.userData.startTime = null;
      
      blocksGroup.add(block);
      blocks.push(block);
    });

    // Easing functions
    function easeOutCubic(t: number): number {
      return 1 - Math.pow(1 - t, 3);
    }
    
    function easeOutBounce(t: number): number {
      const n1 = 7.5625;
      const d1 = 2.75;
      if (t < 1 / d1) {
        return n1 * t * t;
      } else if (t < 2 / d1) {
        return n1 * (t -= 1.5 / d1) * t + 0.75;
      } else if (t < 2.5 / d1) {
        return n1 * (t -= 2.25 / d1) * t + 0.9375;
      } else {
        return n1 * (t -= 2.625 / d1) * t + 0.984375;
      }
    }

    // Animation timing
    const clock = new THREE.Clock();
    const animationDuration = 1.0; // seconds per block drop
    const spinDuration = 1.5; // seconds for spin
    const liftHeight = 0.6; // how high the cube lifts during spin
    const dropDuration = 0.5; // seconds for drop + bounce
    const loopDelay = 1.0; // seconds to wait before looping
    let loopStartTime = 0;

    function animate() {
      requestAnimationFrame(animate);
      
      const elapsed = clock.getElapsedTime();
      const loopElapsed = elapsed - loopStartTime;
      
      // Timeline
      const lastBlockEndTime = blockConfigs[blockConfigs.length - 1].delay + animationDuration;
      const spinStartTime = lastBlockEndTime + 0.1; // Start spin quickly after last block
      const spinEndTime = spinStartTime + spinDuration;
      const dropEndTime = spinEndTime + dropDuration;
      const totalCycleTime = dropEndTime + loopDelay;
      
      // Check if we should reset (loop)
      if (loopElapsed > totalCycleTime) {
        loopStartTime = elapsed;
        blocks.forEach((block) => {
          block.position.y = block.userData.targetY + 6;
        });
        blocksGroup.rotation.y = 0;
        blocksGroup.position.y = 0;
        return;
      }
      
      // Spin phase with lift
      if (loopElapsed > spinStartTime && loopElapsed < spinEndTime) {
        const spinProgress = (loopElapsed - spinStartTime) / spinDuration;
        const eased = easeOutCubic(spinProgress);
        blocksGroup.rotation.y = eased * Math.PI * 2;
        
        // Lift: rise smoothly, peak at middle of spin
        const liftProgress = Math.sin(spinProgress * Math.PI); // 0 -> 1 -> 0
        blocksGroup.position.y = liftProgress * liftHeight;
      } 
      // Drop phase with bounce
      else if (loopElapsed >= spinEndTime && loopElapsed < dropEndTime) {
        blocksGroup.rotation.y = Math.PI * 2;
        const dropProgress = (loopElapsed - spinEndTime) / dropDuration;
        // Invert bounce: start at liftHeight, bounce down to 0
        const bounceProgress = easeOutBounce(dropProgress);
        blocksGroup.position.y = liftHeight * (1 - bounceProgress);
      }
      // Settled
      else if (loopElapsed >= dropEndTime) {
        blocksGroup.rotation.y = Math.PI * 2;
        blocksGroup.position.y = 0;
      }
      
      // Animate each block dropping in
      blocks.forEach((block, index) => {
        const config = blockConfigs[index];
        const blockTime = loopElapsed - config.delay;
        
        if (blockTime > 0 && blockTime < animationDuration) {
          const t = blockTime / animationDuration;
          const eased = easeOutCubic(t);
          const startY = block.userData.targetY + 6;
          block.position.y = startY - (startY - block.userData.targetY) * eased;
        } else if (blockTime >= animationDuration) {
          block.position.y = block.userData.targetY;
        }
      });

      renderer.render(scene, camera);
    }

    animate();

    // Cleanup on page navigation
    document.addEventListener('astro:before-swap', () => {
      renderer.dispose();
    });
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBlockBuilder);
  } else {
    initBlockBuilder();
  }
  
  document.addEventListener('astro:page-load', initBlockBuilder);
</script>
