</style>

<script>
  const form = document.getElementById('intake-form') as HTMLFormElement;
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
  const formError = document.getElementById('form-error') as HTMLDivElement;
  const formSuccess = document.getElementById('form-success') as HTMLDivElement;
  const formStartTimeInput = document.getElementById('form-start-time') as HTMLInputElement;
  const honeypotInput = document.getElementById('website-url') as HTMLInputElement;

  let formStartTime = Date.now();
  formStartTimeInput.value = formStartTime.toString();

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Spam check
    if (honeypotInput?.value || Date.now() - formStartTime < 3000) {
      formSuccess.hidden = false;
      return;
    }

    // Basic validation
    if (!form.checkValidity()) {
      formError.hidden = false;
      formSuccess.hidden = true;
      return;
    }

    // Set loading
    submitButton.disabled = true;
    submitButton.setAttribute('data-loading', 'true');
    formError.hidden = true;

    try {
      // Collect form data
      const formData = new FormData(form);
      const data: Record<string, any> = {};
      
      formData.forEach((value, key) => {
        if (data[key]) {
          // Handle multiple values (checkboxes)
          if (Array.isArray(data[key])) {
            data[key].push(value);
          } else {
            data[key] = [data[key], value];
          }
        } else {
          data[key] = value;
        }
      });

      // Simulate submission (replace with actual API call)
      console.log('Intake form data:', JSON.stringify(data, null, 2));
      await new Promise(resolve => setTimeout(resolve, 1500));

      formSuccess.hidden = false;
      form.reset();
      formStartTime = Date.now();
      formStartTimeInput.value = formStartTime.toString();

    } catch (error) {
      console.error('Submission error:', error);
      formError.hidden = false;
    } finally {
      submitButton.disabled = false;
      submitButton.setAttribute('data-loading', 'false');
    }
  });
</script>
